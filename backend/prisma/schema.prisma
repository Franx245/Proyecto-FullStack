generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Card {
  id                Int         @id @default(autoincrement())
  name              String
  ygoproId          Int         @unique
  description       String      @default("")
  image             String?
  cardType          String      @default("Unknown")
  race              String?
  attribute         String?
  archetype         String?
  atk               Int?
  def               Int?
  level             Int?
  rarity            String      @default("Unknown")
  setName           String      @default("YGOPRODeck")
  setCode           String      @default("")
  price             Float
  stock             Int
  lowStockThreshold Int         @default(3)
  isVisible         Boolean     @default(true)
  isFeatured        Boolean     @default(false)
  isNewArrival      Boolean     @default(false)
  salesCount        Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orderItems        OrderItem[]

  @@index([name])
  @@index([cardType])
  @@index([rarity])
}

model CustomCategory {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique
  description String           @default("")
  image       String?
  isVisible   Boolean          @default(true)
  sortOrder   Int              @default(0)
  parentId    Int?
  parent      CustomCategory?  @relation("CustomCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    CustomCategory[] @relation("CustomCategoryHierarchy")
  products    CustomProduct[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([parentId])
  @@index([isVisible])
}

model CustomProduct {
  id          Int                  @id @default(autoincrement())
  title       String
  slug        String               @unique
  description String               @default("")
  price       Float
  isVisible   Boolean              @default(true)
  categoryId  Int
  category    CustomCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images      CustomProductImage[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([categoryId])
  @@index([isVisible])
}

model CustomProductImage {
  id        Int           @id @default(autoincrement())
  productId Int
  url       String
  sortOrder Int           @default(0)
  product   CustomProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Order {
  id                 Int          @id @default(autoincrement())
  userId             Int?
  addressId          Int?
  subtotal           Float        @default(0)
  shippingCost       Float        @default(0)
  total              Float
  status             OrderStatus  @default(PENDING_PAYMENT)
  shippingZone       ShippingZone @default(PICKUP)
  shippingLabel      String       @default("Retiro en persona")
  trackingCode       String?
  trackingVisibleToUser Boolean   @default(false)
  customerName       String?
  customerEmail      String?
  customerPhone      String?
  shippingAddress    String?
  shippingCity       String?
  shippingProvince   String?
  shippingPostalCode String?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  user               User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  address            Address?     @relation(fields: [addressId], references: [id], onDelete: SetNull)
  items              OrderItem[]

  @@index([userId])
  @@index([addressId])
  @@index([status])
  @@index([shippingZone])
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  orderId  Int
  cardId   Int
  quantity Int
  price    Float
  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  card     Card  @relation(fields: [cardId], references: [id])

  @@index([orderId])
  @@index([cardId])
}

model User {
  id                     Int            @id @default(autoincrement())
  email                  String         @unique
  username               String         @unique
  passwordHash           String
  fullName               String
  phone                  String?
  avatarUrl              String?
  role                   UserRole       @default(USER)
  isActive               Boolean        @default(true)
  lastLoginAt            DateTime?
  lastLoginIp            String?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  refreshTokens          RefreshToken[]
  addresses              Address[]
  orders                 Order[]
  activities             UserActivity[]

  @@index([role])
  @@index([createdAt])
}

model Address {
  id            Int          @id @default(autoincrement())
  userId        Int
  label         String       @default("Principal")
  recipientName String
  phone         String?
  line1         String
  line2         String?
  city          String
  state         String       @default("Buenos Aires")
  postalCode    String?
  zone          ShippingZone @default(CABA)
  notes         String?
  isDefault     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@index([userId])
  @@index([zone])
}

model UserActivity {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  ipAddress  String?
  userAgent  String?
  details    String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

enum UserRole {
  USER
  STAFF
  ADMIN
}

enum ShippingZone {
  CABA
  GBA
  INTERIOR
  PICKUP
}