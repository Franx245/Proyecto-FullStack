# Copia este archivo a .env.local para desarrollo local.
# En Vercel, carga estas variables en el proyecto del storefront/API.

# Backend / Prisma
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxxx:password@db.xxxxx.supabase.co:5432/postgres"
NODE_ENV="development"
PORT="3001"
API_PORT="3001"
NEXT_STORE_PORT="3003"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"
ACCESS_TOKEN_SECRET="replace-with-a-different-access-secret"
REFRESH_TOKEN_SECRET="replace-with-a-different-refresh-secret"

# URLs publicas
BACKEND_URL="http://127.0.0.1:3001"
FRONTEND_URL="http://127.0.0.1:5173"
ADMIN_URL="http://127.0.0.1:5174"

# CORS / runtime
CORS_ALLOWED_ORIGINS=""
ALLOW_VERCEL_PREVIEWS="true"
STORE_PORT="5173"
ADMIN_PORT="5174"
API_REQUEST_TIMEOUT_MS="15000"
CHECKOUT_REQUEST_TIMEOUT_MS="45000"
MP_WEBHOOK_TIMEOUT_MS="25000"
ADMIN_CLEAR_ORDERS_TIMEOUT_MS="60000"
CHECKOUT_EXPIRATION_MINUTES="30"
CRON_SECRET="replace-with-a-long-random-secret"
PERF_TRACE_ENABLED="false"
DATABASE_POOL_SIZE="10"
DATABASE_QUEUE_WAIT_MS="5000"
SSE_MAX_CLIENTS="200"

# Redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
REDIS_TCP_URL="redis://127.0.0.1:6379"

# Mercado Pago
MP_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx"
MP_WEBHOOK_SECRET="your-webhook-signature-secret"
MP_PUBLIC_KEY="APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx"
VITE_MP_PUBLIC_KEY="APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx"

# Storefront
VITE_APP_NAME="DuelVault"
VITE_APP_ENV="development"
VITE_API_BASE_URL="http://127.0.0.1:3001"
VITE_API_TIMEOUT="10000"
VITE_AUTH_PROVIDER="base44"
VITE_AUTH_DOMAIN=""
VITE_AUTH_CLIENT_ID=""
VITE_ENABLE_CART="true"
VITE_ENABLE_ORDERS="true"
VITE_ENABLE_ANALYTICS="false"
VITE_ENABLE_PERF_TRACE="false"
VITE_ANALYTICS_ID=""
VITE_STOREFRONT_URL="http://127.0.0.1:5173"

# Integraciones opcionales del storefront
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"
VITE_ENABLE_SUPABASE_REALTIME="false"
VITE_SUPABASE_SCHEMA="public"
VITE_SUPABASE_CARDS_TABLE="cards"

# Next storefront
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:3003"
NEXT_PUBLIC_APP_NAME="DuelVault"
NEXT_PUBLIC_APP_ENV="development"
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:3001"
NEXT_PUBLIC_API_TIMEOUT="10000"
NEXT_PUBLIC_AUTH_PROVIDER="base44"
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_LEGACY_STOREFRONT_URL="http://127.0.0.1:5173"
NEXT_PUBLIC_ENABLE_CART="true"
NEXT_PUBLIC_ENABLE_ORDERS="true"
NEXT_PUBLIC_ENABLE_ANALYTICS="false"
NEXT_PUBLIC_ENABLE_PERF_TRACE="false"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-public-anon-key"
NEXT_PUBLIC_ENABLE_SUPABASE_REALTIME="false"
NEXT_PUBLIC_SUPABASE_SCHEMA="public"
NEXT_PUBLIC_SUPABASE_CARDS_TABLE="cards"

# Integraciones opcionales del backend
ENVIA_API_KEY=""
ENVIA_WEBHOOK_SECRET=""
ENVIA_BASE_URL="https://api-test.envia.com"
SUPPORT_WHATSAPP_NUMBER=""
SUPPORT_EMAIL=""