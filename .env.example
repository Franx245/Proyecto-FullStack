# Frontend storefront
# Copiá este archivo a .env.local para desarrollo local.

VITE_APP_NAME=DuelVault
VITE_APP_ENV=development

# URL base efectiva usada por el storefront.
VITE_API_BASE_URL=http://127.0.0.1:3001
VITE_API_TIMEOUT=10000

# Integraciones opcionales
VITE_AUTH_PROVIDER=base44
VITE_AUTH_DOMAIN=
VITE_AUTH_CLIENT_ID=
VITE_MP_PUBLIC_KEY=
VITE_ANALYTICS_ID=

# Feature flags
VITE_ENABLE_CART=true
VITE_ENABLE_ORDERS=true
VITE_ENABLE_ANALYTICS=false