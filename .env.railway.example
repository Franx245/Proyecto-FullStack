# ── Railway Backend Environment Variables ──
# Copy to Railway service environment

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://...@pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://...@db.xxx.supabase.co:5432/postgres

# Redis TCP (Railway Redis — for BullMQ + pub/sub)
REDIS_URL=redis://default:xxx@containers-us-xxx.railway.app:6379

# Redis REST (Upstash — for cache)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Auth
ACCESS_TOKEN_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-xxx
MP_WEBHOOK_SECRET=xxx

# CORS / frontend URLs
FRONTEND_URL=https://duelvault-store-api.vercel.app
ADMIN_URL=https://duelvault-admin.vercel.app
BACKEND_URL=https://your-app.railway.app
CORS_ALLOWED_ORIGINS=

# Cloudinary (shared with frontend)
CLOUDINARY_CLOUD_NAME=your-cloud

# Cron auth
CRON_SECRET=change-me

# Runtime
NODE_ENV=production
PORT=3001
