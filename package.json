{
  "name": "duelvault",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend-admin"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node backend/server.js",
    "start:worker": "node backend/worker.js",
    "setup": "prisma generate && prisma db push && prisma db seed",
    "setup:dev": "prisma db push --skip-generate && prisma db seed",
    "postinstall": "prisma generate",
    "db": "prisma db push",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:deploy": "prisma migrate deploy",
    "dev": "node scripts/dev-stack.mjs",
    "dev:api": "node backend/server.js",
    "dev:api:watch": "node --watch backend/server.js",
    "dev:store": "vite --configLoader runner",
    "dev:store:next": "node scripts/dev-next-store.mjs",
    "dev:store:next:raw": "next dev",
    "dev:admin": "npm run dev --workspace frontend-admin",
    "build": "npm run build:store && npm run build:admin",
    "build:store": "vite build --configLoader runner",
    "build:store:next": "next build",
    "build:admin": "npm run build --workspace frontend-admin",
    "start:store:next": "next start",
    "start:store:next:local": "npm run build:store:next && next start -p 3003",
    "preview": "vite preview --configLoader runner",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/query-sync-storage-persister": "^5.90.2",
    "@tanstack/react-query": "^5.84.1",
    "@tanstack/react-query-persist-client": "^5.90.2",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compression": "^1.8.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "embla-carousel-react": "^8.6.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.475.0",
    "mercadopago": "^2.12.0",
    "next": "^14.2.25",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.26.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "critters": "^0.0.23",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.14.0",
    "jiti": "^2.6.1",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.1.0"
  }
}
