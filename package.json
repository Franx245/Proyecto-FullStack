{
  "name": "duelvault",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend-admin"
  ],
  "prisma": {
    "seed": "node backend/prisma/seed.js"
  },
  "scripts": {
    "setup": "prisma generate --schema backend/prisma/schema.prisma && prisma db push --schema backend/prisma/schema.prisma && prisma db seed --schema backend/prisma/schema.prisma",
    "setup:dev": "prisma db push --skip-generate --schema backend/prisma/schema.prisma && prisma db seed --schema backend/prisma/schema.prisma",
    "postinstall": "npm run setup",
    "dev": "node scripts/dev-stack.mjs",
    "dev:api": "node backend/server.js",
    "dev:api:watch": "node --watch backend/server.js",
    "dev:store": "vite",
    "dev:admin": "npm run dev --workspace frontend-admin",
    "build": "npm run build:store && npm run build:admin",
    "build:store": "vite build",
    "build:admin": "npm run build --workspace frontend-admin",
    "preview": "vite preview",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.84.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "embla-carousel-react": "^8.6.0",
    "express": "^5.1.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.475.0",
    "react": "^18.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.26.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.14.0",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.1.0"
  }
}
